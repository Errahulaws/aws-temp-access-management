# =============================================================
#  IAM Access Platform — Production Environment Configuration
# =============================================================
# NO SECRETS HERE — DB_PASSWORD, JWT_SECRET, and STS_EXTERNAL_ID
# are fetched from AWS Secrets Manager at runtime via instance role.
# =============================================================

# AWS region for Secrets Manager and S3
AWS_REGION=us-west-2

# Secrets Manager secret name containing:
#   DB_PASSWORD, JWT_SECRET, JUMPCLOUD_CLIENT_ID, JUMPCLOUD_CLIENT_SECRET, STS_EXTERNAL_ID
APP_SECRET_NAME=iam-platform/app-secrets

# The URL your team will use to access the app (must be HTTPS for SSO)
APP_URL=https://<YOUR-EC2-IP-OR-DOMAIN>

# S3 bucket for audit log archival
AUDIT_S3_BUCKET=your-audit-logs-bucket

# Days to retain audit logs in database before archiving to S3
AUDIT_RETENTION_DAYS=7

# JumpCloud OIDC SSO
JUMPCLOUD_ISSUER=https://oauth.id.jumpcloud.com/

# Map JumpCloud groups to application roles (group:ROLE pairs, comma-separated)
SSO_GROUP_MAPPING=IamPlatform-Requesters:REQUESTER,IamPlatform-Approvers:APPROVER,IamPlatform-Auditors:AUDITOR

# =============================================================
# Account Configuration
# =============================================================
# Every account must be explicitly configured. Account selection is mandatory.
# Pattern: ACCOUNT_<12-digit-id>_*
#
# Required per account:
#   ACCOUNT_<ACCOUNT_ID>_ROLE_ARN              — IAM role to assume via STS
#   ACCOUNT_<ACCOUNT_ID>_LABEL                 — Human-readable name in the UI
#   TEAM_<TEAM>_<ACCOUNT_ID>_POLICY_ARN        — IAM policy ARN for each team
#   ROLE_ID_<ROLE>_<ACCOUNT_ID>                — AWS Role ID (AROA...) for each role level
#
# Teams that don't have TEAM_<TEAM>_<ACCOUNT_ID>_POLICY_ARN set won't appear.
# Role levels that don't have ROLE_ID_<ROLE>_<ACCOUNT_ID> set won't appear.

# --- Account: 123456789012 (Primary) ---
ACCOUNT_123456789012_ROLE_ARN=arn:aws:iam::123456789012:role/IAMPlatformCrossAccountRole
ACCOUNT_123456789012_LABEL="Primary Account"

# Teams for 123456789012
#TEAM_DEVELOPER_123456789012_POLICY_ARN=arn:aws:iam::123456789012:policy/developer-secret-access
TEAM_DEVOPS_123456789012_POLICY_ARN=arn:aws:iam::123456789012:policy/devops-secret-access
TEAM_SECURITY_123456789012_POLICY_ARN=arn:aws:iam::123456789012:policy/security-secret-access

# Role IDs for 123456789012
#ROLE_ID_DEVELOPER_123456789012=AROAXXXXXXXXXXXXXXXXX
ROLE_ID_DEVOPS_L1_123456789012=AROAXXXXXXXXXXXXXXXXX
ROLE_ID_DEVOPS_L2_123456789012=AROAYYYYYYYYYYYYYYYYY
#ROLE_ID_DEVOPS_L3_123456789012=AROAXXXXXXXXXXXXXXXXX
ROLE_ID_SECURITY_L1_123456789012=AROAZZZZZZZZZZZZZZZZZZ
ROLE_ID_SECURITY_L2_123456789012=AROAWWWWWWWWWWWWWWWWWWW
#ROLE_ID_SECURITY_L3_123456789012=AROAXXXXXXXXXXXXXXXXX

# --- Account: 111122223333 (Example — uncomment to enable) ---
#ACCOUNT_111122223333_ROLE_ARN=arn:aws:iam::111122223333:role/IAMPlatformCrossAccountRole
#ACCOUNT_111122223333_LABEL=Production Account
#TEAM_DEVOPS_111122223333_POLICY_ARN=arn:aws:iam::111122223333:policy/devops-secret-access
#TEAM_SECURITY_111122223333_POLICY_ARN=arn:aws:iam::111122223333:policy/security-secret-access
#ROLE_ID_DEVOPS_L1_111122223333=AROAXXXXXXXXXXXXXXXXX
#ROLE_ID_DEVOPS_L2_111122223333=AROAXXXXXXXXXXXXXXXXX
#ROLE_ID_SECURITY_L1_111122223333=AROAXXXXXXXXXXXXXXXXX
#ROLE_ID_SECURITY_L2_111122223333=AROAXXXXXXXXXXXXXXXXX

# =============================================================
# Slack User ID Mapping (for tagging approvers in notifications)
# =============================================================
# Format: SLACK_USER_MAP=email1:SLACK_ID1,email2:SLACK_ID2
# Find Slack User IDs: Slack profile > "..." menu > "Copy member ID"
#
# Example:
# SLACK_USER_MAP=approver1@company.com:UXXXXXXXXXX,approver2@company.com:UXXXXXXXXXX
#SLACK_USER_MAP=approver1@company.com:UXXXXXXXXXX,approver2@company.com:UXXXXXXXXXX
